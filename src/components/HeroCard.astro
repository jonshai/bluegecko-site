---
interface Props {
  title: string;
  tagline?: string;
  image?: string;
  href?: string;
}

const { title, tagline, image, href } = Astro.props;

const beforeTitle = Astro.slots.has('before-title')
  ? await Astro.slots.render('before-title')
  : '';
const bodyContent = Astro.slots.has('default')
  ? await Astro.slots.render('default')
  : '';
---

{href ? (
  <a href={href} class="hero-card card">
    {image ? (
      <img src={image} alt={title} class="hero-img" />
    ) : (
      <div class="hero-placeholder">
        <span>Photo coming soon</span>
      </div>
    )}
    <div class="hero-body">
      {beforeTitle && <Fragment set:html={beforeTitle} />}
      <h1 class="hero-title">{title}</h1>
      {tagline && <p class="hero-tagline">{tagline}</p>}
      {bodyContent && <Fragment set:html={bodyContent} />}
    </div>
  </a>
) : (
  <div class="hero-card card">
    {image ? (
      <img src={image} alt={title} class="hero-img" />
    ) : (
      <div class="hero-placeholder">
        <span>Photo coming soon</span>
      </div>
    )}
    <div class="hero-body">
      {beforeTitle && <Fragment set:html={beforeTitle} />}
      <h1 class="hero-title">{title}</h1>
      {tagline && <p class="hero-tagline">{tagline}</p>}
      {bodyContent && <Fragment set:html={bodyContent} />}
    </div>
  </div>
)}

<style>
  .hero-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    overflow: hidden;
    padding: 0;
    text-decoration: none;
    color: inherit;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    min-height: 340px;
  }

  .hero-placeholder {
    background: #ddd;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 340px;
    color: #999;
    font-size: 0.9rem;
  }

  .hero-body {
    padding: 2rem 2.25rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.75rem;
  }

  .hero-title {
    font-size: 1.5rem;
    margin: 0;
    line-height: 1.3;
  }

  .hero-tagline {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-soft);
  }

  @media (max-width: 800px) {
    .hero-card {
      grid-template-columns: 1fr;
    }

    .hero-img,
    .hero-placeholder {
      min-height: 220px;
    }

    .hero-body {
      padding: 1.5rem;
    }
  }
</style>
