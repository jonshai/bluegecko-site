---
interface Props {
  title: string;
  tagline?: string;
  image?: string;
  href?: string;
  layout?: 'side-by-side' | 'stacked';
}

const { title, tagline, image, href, layout = 'side-by-side' } = Astro.props;

const beforeTitle = Astro.slots.has('before-title')
  ? await Astro.slots.render('before-title')
  : '';
const bodyContent = Astro.slots.has('default')
  ? await Astro.slots.render('default')
  : '';

const cardClass = layout === 'stacked' ? 'hero-card hero-card-stacked card' : 'hero-card card';
---

{href ? (
  <a href={href} class={cardClass}>
    {image ? (
      <img src={image} alt={title} class="hero-img" />
    ) : (
      <div class="hero-placeholder">
        <span>Photo coming soon</span>
      </div>
    )}
    <div class="hero-body">
      {beforeTitle && <Fragment set:html={beforeTitle} />}
      <h1 class="hero-title">{title}</h1>
      {tagline && <p class="hero-tagline">{tagline}</p>}
      {bodyContent && <Fragment set:html={bodyContent} />}
    </div>
  </a>
) : (
  <div class={cardClass}>
    {image ? (
      <img src={image} alt={title} class="hero-img" />
    ) : (
      <div class="hero-placeholder">
        <span>Photo coming soon</span>
      </div>
    )}
    <div class="hero-body">
      {beforeTitle && <Fragment set:html={beforeTitle} />}
      <h1 class="hero-title">{title}</h1>
      {tagline && <p class="hero-tagline">{tagline}</p>}
      {bodyContent && <Fragment set:html={bodyContent} />}
    </div>
  </div>
)}

<style>
  /* ── Side-by-side (default — open house hero) ── */
  .hero-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    overflow: hidden;
    padding: 0;
    text-decoration: none;
    color: inherit;
  }

  .hero-card .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    min-height: 340px;
  }

  .hero-card .hero-placeholder {
    background: #ddd;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 340px;
    color: #999;
    font-size: 0.9rem;
  }

  .hero-card .hero-body {
    padding: 2rem 2.25rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.75rem;
  }

  /* ── Stacked (builder detail) ── */
  .hero-card-stacked {
    grid-template-columns: 1fr;
  }

  .hero-card-stacked .hero-img {
    width: 100%;
    height: 420px;
    min-height: unset;
    object-fit: cover;
    display: block;
  }

  .hero-card-stacked .hero-placeholder {
    height: 280px;
    min-height: unset;
  }

  .hero-card-stacked .hero-body {
    padding: 1.75rem 2rem;
    justify-content: flex-start;
  }

  /* ── Shared text styles ── */
  .hero-title {
    font-size: 1.5rem;
    margin: 0;
    line-height: 1.3;
  }

  .hero-tagline {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-soft);
  }

  /* ── Responsive ── */
  @media (max-width: 800px) {
    .hero-card {
      grid-template-columns: 1fr;
    }

    .hero-card .hero-img,
    .hero-card .hero-placeholder {
      min-height: 220px;
    }

    .hero-card .hero-body {
      padding: 1.5rem;
    }

    .hero-card-stacked .hero-img {
      height: 240px;
    }
  }
</style>
