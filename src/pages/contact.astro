---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
---

<BaseLayout
  title="Contact | Blue Gecko"
  description="Get in touch with Blue Gecko for Space Coast real estate guidance."
>
  <main>
    <section class="section hero">
      <div class="container">
        <p class="eyebrow">Contact</p>
        <h1>Start here.</h1>
        <p class="lead">
          Whether you’re planning a move, browsing options, or trying to make sense of
          the local market, this is the fastest way to get pointed in the right direction.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container intro-grid">
        <div class="card">
          <h2>Send a message</h2>
          <p>
            Prefer the straightforward route? Use the form below and tell us what you need.
            We’ll respond with something useful, not a canned follow-up.
          </p>

          <LeadForm
            buttonText="Send Message"
            source="BG Web"
            formType="general-inquiry"
            redirectTo="/thank-you"
            messageLabel="How can we help?"
            showName={true}
            showEmail={true}
            showPhone={true}
            showMessage={true}
            requireName={true}
            requireEmail={true}
            requirePhone={false}
            requireAnyContact={false}
          />
        </div>

        <div class="card">
          <h2>Or start with Stella</h2>
          <p>
            Stella is the site concierge. If you’d rather talk it through than fill out a form,
            she can gather the basics, help narrow your next step, and hand things off when a
            human should step in.
          </p>
          <p>
            Think of her as the guided route: tell her what you want, what you want to spend,
            where you want to be, or what you’re trying to figure out, and she can help you
            get oriented faster.
          </p>
          <div style="margin-top: 1rem;">
            <button data-stella-trigger="open" class="button button-secondary">Talk to Stella</button>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>