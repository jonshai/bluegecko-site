---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
---

<BaseLayout
  title="Contact | Blue Gecko"
  description="Get in touch with Blue Gecko for Space Coast real estate guidance."
>
  <main>
    <section class="section hero">
      <div class="container">
        <p class="eyebrow">Contact</p>
        <h1>Let’s talk.</h1>
        <p class="lead">
          Whether you’re planning a move, browsing options, or trying to make sense of
          the local market, Blue Gecko is here to help.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container intro-grid">
        <div class="card">
          <h2>Start the conversation</h2>
          <p>
            Tell us what you’re looking for and we’ll point you in the right direction
            without the usual real estate theater.
          </p>

          <LeadForm
            buttonText="Send Message"
            source="BG Web"
            formType="general-inquiry"
            redirectTo="/thank-you"
            messageLabel="How can we help?"
            showName={true}
            showEmail={true}
            showPhone={true}
            showMessage={true}
            requireName={true}
            requireEmail={true}
            requirePhone={false}
            requireAnyContact={false}
          />
        </div>

        <div class="card">
          <h2>What this site is for</h2>
          <p>
            We’re building Blue Gecko into a smarter lead and content platform over
            time, but the short version is simple: real help, direct contact, and no
            nonsense.
          </p>
          <p>
            Use this page if you want to talk about buying, selling, open houses, local
            neighborhoods, or where to start.
          </p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>