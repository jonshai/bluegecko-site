---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroCard from '../../components/HeroCard.astro';
import { getCollection } from 'astro:content';
import { getAuthor } from '../../data/authors';
import type { AuthorName } from '../../data/authors';

export async function getStaticPaths() {
  const allBuilders = await getCollection('builders');
  return allBuilders.map(b => ({
    params: { slug: b.id },
    props: { builder: b },
  }));
}

const { builder } = Astro.props;

const author = builder.data.author_name
  ? getAuthor(builder.data.author_name as AuthorName)
  : null;

// Inline markdown renderer — handles paragraphs, headings, lists, bold, italic, links
function inlineToHtml(text: string): string {
  return text
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>')
    .replace(/\*\*\*([^*]+)\*\*\*/g, '<strong><em>$1</em></strong>')
    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
    .replace(/\*([^*\n]+)\*/g, '<em>$1</em>')
    .replace(/_([^_\n]+)_/g, '<em>$1</em>')
    .replace(/`([^`]+)`/g, '<code>$1</code>');
}

function blockToHtml(block: string): string {
  const trimmed = block.trim();
  if (!trimmed) return '';

  const h4 = trimmed.match(/^#### (.+)/);
  if (h4) return `<h4>${inlineToHtml(h4[1].trim())}</h4>`;
  const h3 = trimmed.match(/^### (.+)/);
  if (h3) return `<h3>${inlineToHtml(h3[1].trim())}</h3>`;
  const h2 = trimmed.match(/^## (.+)/);
  if (h2) return `<h2>${inlineToHtml(h2[1].trim())}</h2>`;
  const h1 = trimmed.match(/^# (.+)/);
  if (h1) return `<h1>${inlineToHtml(h1[1].trim())}</h1>`;

  const lines = trimmed.split('\n');
  if (lines.length > 0 && lines.every(l => l.trim().match(/^[-*+] /))) {
    const items = lines
      .filter(l => l.trim())
      .map(l => `<li>${inlineToHtml(l.replace(/^[-*+] /, '').trim())}</li>`)
      .join('');
    return `<ul>${items}</ul>`;
  }

  const content = lines.map(l => inlineToHtml(l.trim())).join(' ');
  return `<p>${content}</p>`;
}

// Build interleaved prose + gallery HTML
const rawBlocks = (builder.body ?? '').split(/\n\n+/).filter((b: string) => b.trim());
const gallery: string[] = builder.data.gallery ?? [];

function galleryImg(index: number): string {
  return `<img src="${gallery[index]}" alt="${builder.data.name} gallery image ${index + 1}" loading="lazy" class="gallery-inline" />`;
}

const htmlParts: string[] = [];
let galleryIndex = 0;

// Prefer placing images before h2/h3 headings if any exist
const hasHeadings = rawBlocks.some(b => b.trim().match(/^#{2,3} /));

if (hasHeadings) {
  for (const block of rawBlocks) {
    const isSection = block.trim().match(/^#{2,3} /);
    if (isSection && galleryIndex < gallery.length) {
      htmlParts.push(galleryImg(galleryIndex++));
    }
    const blockHtml = blockToHtml(block);
    if (blockHtml) htmlParts.push(blockHtml);
  }
} else {
  // Fallback: one image per 3 content blocks
  let blockCount = 0;
  for (const block of rawBlocks) {
    const blockHtml = blockToHtml(block);
    if (blockHtml) {
      htmlParts.push(blockHtml);
      blockCount++;
      if (blockCount % 3 === 0 && galleryIndex < gallery.length) {
        htmlParts.push(galleryImg(galleryIndex++));
      }
    }
  }
}

// Append any remaining gallery images after all content
while (galleryIndex < gallery.length) {
  htmlParts.push(galleryImg(galleryIndex++));
}

const interleavedHtml = htmlParts.join('\n');
---

<BaseLayout
  title={`${builder.data.name} | Builders | Blue Gecko`}
  description={builder.data.tagline}
>
  <main>
    <section class="section hero-section">
      <div class="container">
        <HeroCard
          title={builder.data.name}
          tagline={builder.data.tagline}
          image={builder.data.hero}
          layout="stacked"
        />
      </div>
    </section>

    <section class="section">
      <div class="container content-wrap">
        <nav class="breadcrumb">
          <a href="/builders">← All Builders</a>
        </nav>

        {(author || builder.data.date || builder.data.last_updated) && (
          <div class="article-meta">
            {author && <span class="author">{author.name}</span>}
            {builder.data.date && (
              <span class="pub-date">
                {builder.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
            )}
            {builder.data.last_updated && (
              <span class="last-updated">
                Updated {builder.data.last_updated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
            )}
          </div>
        )}

        {builder.data.website && (
          <div class="website-row">
            <a
              href={builder.data.website}
              target="_blank"
              rel="noopener noreferrer"
              class="website-link"
            >
              Official Site →
            </a>
          </div>
        )}

        {builder.data.communities && builder.data.communities.length > 0 && (
          <div class="communities-row">
            <span class="communities-label">Active communities:</span>
            <div class="community-chips">
              {builder.data.communities.map((slug: string) => (
                <a href={`/communities/${slug}`} class="community-chip">
                  {slug.replace(/-/g, ' ')}
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="prose" set:html={interleavedHtml} />

        {author && (
          <section class="author-byline">
            <h2>About the Author</h2>
            <div class="byline-inner">
              <img
                src={author.photo}
                alt={`Photo of ${author.name}`}
                class="author-photo"
                loading="lazy"
              />
              <p class="author-bio">{author.bio}</p>
            </div>
          </section>
        )}

        <div class="agent-pitch card">
          <h3>Why you still need your own agent.</h3>
          <p>
            The builder's sales agent works for the builder — their job is to protect the builder's
            margin and close the deal. That's not a judgment, it's just how it works. Having Blue
            Gecko represent you costs you nothing (the builder pays buyer's agent commission), and
            means you have someone in your corner on contract terms, inspections, upgrades, and the
            parts of the process where builders have the advantage.
          </p>
          <p>
            We've walked through more new construction on the Space Coast than we can count. We know
            what's negotiable, what isn't, and when to push.
          </p>
        </div>

        <div class="cta-row">
          <a href="/contact" class="button button-primary">Talk to Us First</a>
          <button data-stella-trigger="open" class="button button-secondary">Ask Stella</button>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero-section {
    padding-top: 2rem;
  }

  .content-wrap {
    max-width: 780px;
  }

  .breadcrumb {
    font-size: 0.88rem;
    margin-bottom: 1.25rem;
  }

  .breadcrumb a {
    color: var(--brand, #1f5c4d);
    font-weight: 600;
  }

  .website-row {
    margin-bottom: 1.5rem;
  }

  .website-link {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--brand, #1f5c4d);
    text-decoration: none;
  }

  .website-link:hover {
    text-decoration: underline;
  }

  .communities-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #e8e6e0;
  }

  .communities-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-soft);
  }

  .community-chips {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .community-chip {
    background: #e8e6e0;
    color: var(--text);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    text-decoration: none;
    text-transform: capitalize;
    transition: background 0.15s;
  }

  .community-chip:hover {
    background: var(--brand, #1f5c4d);
    color: white;
  }

  .prose {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text);
    margin-bottom: 2rem;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose :global(h2) {
    font-size: 1.35rem;
    margin: 2rem 0 0.75rem;
    color: var(--text);
  }

  .prose :global(h3) {
    font-size: 1.15rem;
    margin: 1.5rem 0 0.5rem;
    color: var(--text);
  }

  .prose :global(h4) {
    font-size: 1rem;
    margin: 1.25rem 0 0.4rem;
    color: var(--text);
  }

  .prose :global(ul) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
  }

  .prose :global(a) {
    color: var(--brand, #1f5c4d);
    text-decoration: underline;
  }

  .prose :global(code) {
    font-size: 0.9em;
    background: #e8e6e0;
    padding: 0.1em 0.35em;
    border-radius: 4px;
  }

  .prose :global(.gallery-inline) {
    width: 100%;
    border-radius: var(--radius, 18px);
    display: block;
    margin: 1.75rem 0;
    object-fit: cover;
  }

  .agent-pitch {
    background: #f0f7f4;
    border: none;
    padding: 1.75rem 2rem;
    margin-bottom: 2rem;
  }

  .agent-pitch h3 {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
    color: var(--brand, #1f5c4d);
  }

  .agent-pitch p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-soft);
    margin-bottom: 0.75rem;
  }

  .agent-pitch p:last-child {
    margin-bottom: 0;
  }

  .cta-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 1.5rem;
    border-top: 1px solid #e8e6e0;
  }

  /* ── Article meta ── */
  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 0.82rem;
    color: var(--text-soft);
    margin-bottom: 1.25rem;
  }

  .article-meta .author,
  .article-meta .pub-date,
  .article-meta .last-updated {
    font-weight: 600;
  }

  /* ── Author byline ── */
  .author-byline {
    max-width: var(--prose-width, 72ch);
    margin-top: 3rem;
    margin-bottom: 2rem;
  }

  .author-byline h2 {
    font-size: 1.35rem;
    margin: 2rem 0 0.75rem;
    color: var(--text);
  }

  .byline-inner {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .author-photo {
    width: 20%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: var(--radius, 18px);
    flex-shrink: 0;
  }

  .author-bio {
    width: 80%;
    margin: 0;
  }

  @media (max-width: 600px) {
    .communities-row {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
