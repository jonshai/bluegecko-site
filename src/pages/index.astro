---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Blue Gecko | Space Coast Real Estate"
  description="Find your place on the Space Coast with Blue Gecko. Real estate guidance, open houses, and local expertise from William and Lucky."
>
  <main>
    <section class="hero section hero-home">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Blue Gecko Homes</p>
          <h1>Find your place on the Space Coast.</h1>
          <p class="lead">
            Real estate guidance from real people. Browse homes, explore communities,
            and get local insight without the usual pressure or the usual sales script.
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href="/buy">Browse Homes</a>
            <a class="button button-secondary" href="/contact">Say Hello</a>
          </div>
        </div>

        <div class="hero-media">
          <img src="/assets/team.jpg" alt="Blue Gecko real estate team" />
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container intro-grid">
        <div class="card">
          <h2>More guide, less salesperson.</h2>
          <p>
            Buying or selling a home on the Space Coast can get noisy fast. Blue Gecko
            is built to make the process clearer, calmer, and more useful.
          </p>
        </div>

        <div class="card">
          <h2>Local help, direct contact.</h2>
          <p>
            Work directly with William and Lucky, not a faceless call center or a lead
            desk that forgets your name five minutes later.
          </p>
        </div>
      </div>
    </section>

    <section class="section section-muted">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Featured Open House</p>
          <h2>Tour 5017 Barr St</h2>
          <p>
            Start with one standout home, then use it as a shortcut to similar listings,
            price drops, and nearby opportunities in the same range.
          </p>
        </div>

        <div class="card">
          <h3>See the full open house page</h3>
          <p>
            Get the details, preview the property, and unlock similar homes without
            starting from scratch every time a listing catches your eye.
          </p>
          <a class="text-link" href="/open-house/test-open-house">See open house details</a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container bio-grid">
        <article class="bio-card">
          <img src="/assets/william.jpg" alt="William" />
          <div>
            <h3>William</h3>
            <p>
              Local market guide, strategist, and the part of the operation most likely
              to go deep on pricing, positioning, and the details that actually matter.
            </p>
          </div>
        </article>

        <article class="bio-card">
          <img src="/assets/lucky.jpg" alt="Lucky" />
          <div>
            <h3>Lucky</h3>
            <p>
              Warmth, follow-through, and the human side of the process. The kind of
              steady presence people remember after the paperwork fog clears.
            </p>
          </div>
        </article>
      </div>
    </section>

    <section class="section cta-band">
      <div class="container cta-inner">
        <div>
          <p class="eyebrow">Start here</p>
          <h2>Ready to talk about your next move?</h2>
          <p>
            Whether you’re browsing, planning, or actively hunting, Blue Gecko is built
            to help you move intelligently.
          </p>
        </div>

        <a class="button button-primary" href="/contact">Get in Touch</a>
      </div>
    </section>
  </main>
</BaseLayout>
<style>
  .hero-home {
    padding: 1.75rem 0 2.5rem;
  }

  .hero-home .hero-grid {
    align-items: center;
  }

  .hero-home .hero-media img {
    min-height: 500px;
    object-fit: cover;
    object-position: center top;
  }

  @media (max-width: 900px) {
    .hero-home {
      padding: 1.25rem 0 2rem;
    }

    .hero-home .hero-media img {
      min-height: auto;
    }
  }
</style>