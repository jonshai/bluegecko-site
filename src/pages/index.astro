---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Blue Gecko | Space Coast Real Estate"
  description="Find your place on the Space Coast with Blue Gecko. Real estate guidance, open houses, and local expertise from William and Lucky."
>
  <main>
    <section class="hero section hero-home">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Blue Gecko Homes</p>
          <h1>Find your place on the Space Coast.</h1>
          <p class="lead">
            Real estate guidance from real people. Search homes, explore neighborhoods,
            and get local insight without the usual pressure, noise, or canned sales routine.
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href="/buy">Browse Homes</a>
            <a class="button button-secondary" href="/contact">Say Hello</a>
          </div>
        </div>

        <div class="hero-media">
          <img src="/assets/team.jpg" alt="Blue Gecko real estate team" />
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container intro-grid">
        <div class="card">
          <h2>More guide, less salesperson.</h2>
          <p>
            Buying or selling on the Space Coast gets noisy fast. Blue Gecko is built to make the process clearer,
            calmer, and easier to navigate from first look to closing table.
          </p>
        </div>

        <div class="card">
          <h2>Local help, direct contact.</h2>
          <p>
            Work directly with William and Lucky, not a rotating call center, outsourced ISA,
            or mystery inbox that treats you like a spreadsheet row.
          </p>
        </div>
      </div>
    </section>

    <section class="section section-muted">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Start Here</p>
          <h2>Search on your terms</h2>
          <p>
            Browse live listings directly, or let Stella help you narrow the field before you dive into the full search.
          </p>
        </div>

        <div class="intro-grid home-action-grid">
          <div class="card home-action-card">
            <h3>Search Homes</h3>
            <p>
              Jump straight into the live search experience with map, filters, and current listings across the Space Coast.
            </p>
            <a class="button button-primary" href="/search">Open Home Search</a>
          </div>

          <div class="card home-action-card">
            <h3>Need a smarter starting point?</h3>
            <p>
              Stella is the website concierge. Tell her what you want, what you want to spend, and where you want to be,
              and she can point you toward the right homes faster.
            </p>
            <button data-stella-trigger="open" class="button button-secondary">Start with Stella</button>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container bio-grid">
        <article class="bio-card">
          <img src="/assets/william.jpg" alt="William" />
          <div>
            <h3>William</h3>
            <p>
              Local market guide, strategist, and the one most likely to go deep on pricing,
              positioning, and the details that can save you money or keep you out of trouble.
            </p>
          </div>
        </article>

        <article class="bio-card">
          <img src="/assets/lucky.jpg" alt="Lucky" />
          <div>
            <h3>Lucky</h3>
            <p>
              Warmth, follow-through, and the human side of the process. The kind of
              steady presence people remember after the paperwork fog clears.
            </p>
          </div>
        </article>
      </div>
    </section>

    <section class="section cta-band">
      <div class="container cta-inner">
        <div>
          <p class="eyebrow">Start here</p>
          <h2>Ready to talk about your next move?</h2>
          <p>
            Whether you’re browsing, planning, or actively house hunting, Blue Gecko is built
            to help you move with more clarity and less chaos.
          </p>
        </div>

        <a class="button button-primary" href="/contact">Get in Touch</a>
      </div>
    </section>
  </main>
</BaseLayout>
<style>
  .hero-home {
    padding: 1.75rem 0 2.5rem;
  }

  .hero-home .hero-grid {
    align-items: center;
  }

  .hero-home .hero-media img {
    min-height: 500px;
    object-fit: cover;
    object-position: center top;
  }

  .home-action-grid {
    align-items: stretch;
  }

  .home-action-card {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .home-action-card .button {
    align-self: flex-start;
    margin-top: auto;
  }

  @media (max-width: 900px) {
    .hero-home {
      padding: 1.25rem 0 2rem;
    }

    .hero-home .hero-media img {
      min-height: auto;
    }
  }
</style>