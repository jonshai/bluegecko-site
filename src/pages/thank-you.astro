---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Thank You | Blue Gecko">
  <main class="section">
    <div class="container">
      <div class="card">
        <h1>You're in.</h1>
        <p>
          We’ve got your info and will send you the details shortly.
        </p>
        <p>
          In the meantime, we’ll also keep an eye out for similar homes,
          price drops, and opportunities that match what you're looking for.
        </p>
      </div>
    </div>
  </main>
</BaseLayout>