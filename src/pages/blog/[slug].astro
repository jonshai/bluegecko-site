---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const sorted = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  return sorted.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: sorted[i + 1] ?? null,
      next: sorted[i - 1] ?? null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);

function formatDate(d: Date): string {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout
  title={`${post.data.title} | Blue Gecko`}
  description={post.data.excerpt}
>
  <main>
    <section class="section hero-section">
      <div class="container">
        <nav class="breadcrumb">
          <a href="/blog">← Back to Blog</a>
        </nav>

        <div class="hero-card">
          {post.data.hero
            ? <img src={post.data.hero} alt={post.data.title} class="hero-img" />
            : <div class="hero-placeholder" />
          }
          <div class="hero-meta">
            <div class="meta-row">
              <span class="post-date">{formatDate(post.data.date)}</span>
              {post.data.last_updated && (
                <>
                  <span class="meta-sep">·</span>
                  <span class="last-updated">Updated {formatDate(post.data.last_updated)}</span>
                </>
              )}
              <span class="meta-sep">·</span>
              <span class="post-author">{post.data.author_name}</span>
            </div>
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="post-tags">
                {post.data.tags.map(tag => (
                  <a
                    href={`/blog/tag/${tag.toLowerCase().replace(/\s+/g, '-')}`}
                    class="tag-chip"
                  >{tag}</a>
                ))}
              </div>
            )}
            <h1>{post.data.title}</h1>
            <p class="hero-excerpt">{post.data.excerpt}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container content-wrap">
        <div class="prose">
          <Content />
        </div>

        {post.data.author_photo && (
          <section class="author-byline">
            <h2>About the Author</h2>
            <div class="byline-inner">
              <img
                src={post.data.author_photo}
                alt={`Photo of ${post.data.author_name}`}
                class="author-photo"
                loading="lazy"
              />
              <p class="author-bio">{post.data.author_bio}</p>
            </div>
          </section>
        )}

        <div class="cta-row">
          <button data-stella-trigger="open" class="button button-primary">Ask Stella</button>
          <a href="/contact" class="button button-secondary">Talk to Us</a>
        </div>

        {(prev || next) && (
          <nav class="post-nav">
            <div class="post-nav-item">
              {prev && (
                <a href={`/blog/${prev.id}`} class="post-nav-link post-nav-prev">
                  <span class="nav-label">← Older</span>
                  <span class="nav-title">{prev.data.title}</span>
                </a>
              )}
            </div>
            <div class="post-nav-item post-nav-right">
              {next && (
                <a href={`/blog/${next.id}`} class="post-nav-link post-nav-next">
                  <span class="nav-label">Newer →</span>
                  <span class="nav-title">{next.data.title}</span>
                </a>
              )}
            </div>
          </nav>
        )}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ── Hero card ── */
  .hero-section {
    padding-bottom: 0;
  }

  .breadcrumb {
    font-size: 0.88rem;
    margin-bottom: 1.5rem;
  }

  .breadcrumb a {
    color: var(--brand, #1f5c4d);
    font-weight: 600;
  }

  .hero-card {
    display: flex;
    border-radius: var(--radius, 18px);
    overflow: hidden;
    background: var(--surface, #fff);
    border: 1px solid var(--line, #d7d1c5);
    box-shadow: var(--shadow, 0 10px 30px rgba(0, 0, 0, 0.08));
  }

  .hero-img,
  .hero-placeholder {
    width: 55%;
    flex-shrink: 0;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  .hero-placeholder {
    background: var(--brand, #1f5c4d);
  }

  .hero-meta {
    flex: 1;
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    justify-content: center;
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 0.82rem;
    color: var(--text-soft);
  }

  .meta-sep {
    opacity: 0.4;
  }

  .post-date,
  .post-author {
    font-weight: 600;
  }

  .post-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag-chip {
    background: #e8e6e0;
    color: var(--text);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    text-decoration: none;
  }

  .tag-chip:hover {
    background: var(--brand, #1f5c4d);
    color: white;
  }

  .hero-meta h1 {
    font-size: 1.45rem;
    line-height: 1.25;
    margin: 0;
  }

  .hero-excerpt {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-soft);
  }

  /* ── Article prose ── */
  .content-wrap {
    max-width: 740px;
    padding-top: 2.5rem;
  }

  .prose {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text);
  }

  .prose p {
    margin-bottom: 1.25rem;
  }

  .prose h2 {
    font-size: 1.35rem;
    margin: 2rem 0 0.75rem;
  }

  .prose h3 {
    font-size: 1.15rem;
    margin: 1.75rem 0 0.5rem;
  }

  .cta-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid #e8e6e0;
  }

  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid #e8e6e0;
  }

  .post-nav-item {
    flex: 1;
  }

  .post-nav-right {
    text-align: right;
  }

  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    text-decoration: none;
    color: var(--text);
  }

  .post-nav-link:hover .nav-title {
    color: var(--brand, #1f5c4d);
  }

  .nav-label {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--text-soft);
    text-transform: uppercase;
  }

  .nav-title {
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.3;
    transition: color 0.15s;
  }

  /* ── Author byline ── */
  .author-byline {
    max-width: var(--prose-width, 72ch);
    margin-top: 3rem;
  }

  .author-byline h2 {
    font-size: 1.35rem;
    margin: 2rem 0 0.75rem;
  }

  .byline-inner {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .author-photo {
    width: 20%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: var(--radius, 18px);
    flex-shrink: 0;
  }

  .author-bio {
    width: 80%;
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .hero-card {
      flex-direction: column;
    }

    .hero-img,
    .hero-placeholder {
      width: 100%;
      aspect-ratio: 4 / 3;
    }

    .hero-meta h1 {
      font-size: 1.2rem;
    }
  }
</style>
