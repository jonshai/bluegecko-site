---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
---

<BaseLayout title="List My House | Blue Gecko">
  <main>
    <section class="hero section">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Seller • Early Insight</p>
          <h1>Get a Smarter Read on What Your Home Could Sell For</h1>
          <p class="lead">
            Get a realistic price range based on what buyers are actually paying right now,
            not a generic estimate that misses condition, upgrades, timing, and neighborhood nuance.
          </p>

          <div class="event-meta">
            <p><strong>What you get:</strong> Price range + selling strategy</p>
            <p><strong>Turnaround:</strong> Usually same day</p>
            <p><strong>No pressure:</strong> Useful guidance, not a listing trap</p>
          </div>
        </div>

        <div class="hero-image card seller-hero-card">
          <div class="seller-hero-copy">
            <p class="eyebrow">Why this works better</p>
            <h2>Fast is easy. Useful is better.</h2>
            <p>
              Automated values are fine for curiosity. This is for people who want a sharper,
              more grounded range based on real comps, buyer behavior, and what is happening
              in your exact slice of the market.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container grid-2">
        <div class="card">
          <h2>Get your home value</h2>
          <p>
            Tell us a little about your property and we’ll send a realistic price range,
            along with the local factors that are helping or hurting value right now.
          </p>

          <LeadForm
            buttonText="Get My Home Value"
            source="BG Web"
            formType="seller"
            redirectTo="/thank-you"
            messageLabel="Tell us about your home (optional)"
            showName={true}
            showEmail={true}
            showPhone={true}
            showMessage={true}
            requireAnyContact={true}
          />
        </div>

        <div class="card">
          <h2>What you’ll get</h2>
          <p>
            This is for homeowners who want useful guidance before deciding whether to sell,
            wait, improve the property, or shift strategy.
          </p>

          <ul class="feature-list">
            <li>Real comps, not broad automated estimates</li>
            <li>Adjustments for upgrades, condition, and presentation</li>
            <li>Insight into what buyers are prioritizing right now</li>
            <li>Timing guidance for when to list and how to position it</li>
            <li>No obligation, no pressure, no automatic listing pitch</li>
          </ul>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>