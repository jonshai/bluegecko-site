      ss_description: 'Grant-Valkaria, FL 32909',
      center_lat: '27.8990653',
      center_lon: '-80.6437906',
      center_lat_pan: '27.93334705710874',
      center_lon_pan: '-80.65738450000002',
      user_lat: '27.8990653',
      user_lon: '-80.6437906',
      geotype: 'Postcode1',
      geospatial: 'true',
      zoom: '12',
      sort_by: '1',
      bounds_north: '28.026578687894684',
      bounds_east: '-80.52211533496096',
      bounds_south: '27.840034919389257',
      bounds_west: '-80.79265366503908',
    },
    'viera': {
      location_search_field: 'Viera',
      ss_description: 'Viera, FL',
      center_lat: '28.2666258',
      center_lon: '-80.72905589999999',
      center_lat_pan: '28.2300683795942',
      center_lon_pan: '-80.73033065',
      user_lat: '28.2666258',
      user_lon: '-80.72905589999999',
      geotype: 'Neighborhood',
      geospatial: 'true',
      zoom: '12',
      sort_by: '1',
      bounds_north: '28.323042367845282',
      bounds_east: '-80.59506148496094',
      bounds_south: '28.137013323469407',
      bounds_west: '-80.86559981503906',
    }
  };

  const MAPBOX_TOKEN = import.meta.env.PUBLIC_MAPBOX_TOKEN || '';

  const encode = (value) => encodeURIComponent(String(value));

  const findKnownLocation = (value) => {
    const key = value.toLowerCase().trim();
    const normalizedKey = key.replace(/,\s*fl$/i, '').trim();
    return KNOWN_LOCATIONS[key] || KNOWN_LOCATIONS[normalizedKey] || null;
  };

  const resolveWithMapbox = async (value) => {
    if (!MAPBOX_TOKEN) return null;

    const url = `https://api.mapbox.com/geocoding/v5/mapbox.places/${encodeURIComponent(value)}.json?access_token=${MAPBOX_TOKEN}&country=us&proximity=-80.5886646,28.0344621&types=place,postcode,neighborhood,locality`;

    try {
      const response = await fetch(url);
      if (!response.ok) return null;

      const data = await response.json();
      const feature = data?.features?.[0];
      if (!feature) return null;

      const [lon, lat] = feature.center || [];
      if (typeof lat !== 'number' || typeof lon !== 'number') return null;

      const placeType = feature.place_type?.[0] || 'place';
      const geotypeMap = {
        postcode: 'Postcode1',
        neighborhood: 'Neighborhood',
        locality: 'PopulatedPlace',
        place: 'PopulatedPlace'
      };

      return {
        location_search_field: feature.text || value,
        ss_description: feature.place_name || value,
        center_lat: String(lat),
        center_lon: String(lon),
        center_lat_pan: String(lat),
        center_lon_pan: String(lon),
        user_lat: String(lat),
        user_lon: String(lon),
        bounds_north: String(lat + 0.08),
        bounds_east: String(lon + 0.12),
        bounds_south: String(lat - 0.08),
        bounds_west: String(lon - 0.12),
        geotype: geotypeMap[placeType] || 'PopulatedPlace',
        geospatial: 'true',
        zoom: placeType === 'postcode' ? '13' : '12',
        sort_by: '1'
      };
    } catch {
      return null;
    }
  };

  form.addEventListener('submit', async function (e) {
    e.preventDefault();

    const location = document.getElementById('location').value.trim();

    if (!location) return;

    const toTitleCase = (value) =>
      value.replace(/\b\w+/g, (word) => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase());

    // --- Parse beds first so ranges like "3-4 beds" don't get mistaken for price ---
    let beds = '';
    const bedRangeMatch = location.match(/(\d+)\s*(?:-|to)\s*(\d+)\s*(beds?|br|bedroom|bedrooms)/i);
    const bedSingleMatch = location.match(/(\d+)\s*\+?\s*(beds?|br|bedroom|bedrooms)/i);

    if (bedRangeMatch) {
      beds = bedRangeMatch[1];
    } else if (bedSingleMatch) {
      beds = bedSingleMatch[1];
    }

    // --- Extract & sanitize location (remove price/bed language first) ---
    let working = location;

    working = working
      .replace(/\bunder\s*\$?\d[\d,.]*[kKmM]?\b/gi, '')
      .replace(/\bover\s*\$?\d[\d,.]*[kKmM]?\b/gi, '')
      .replace(/\b\$?\d[\d,.]*[kKmM]?\s*(?:-|to)\s*\$?\d[\d,.]*[kKmM]?\b/gi, '')
      .replace(/\b\d+\s*(?:-|to)\s*\d+\s*(beds?|br|bedroom|bedrooms)\b/gi, '')
      .replace(/\b\d+\s*\+?\s*(beds?|br|bedroom|bedrooms)\b/gi, '')
      .replace(/\$/g, '')
      .trim();

    working = working.replace(/\s+/g, ' ').trim();

    // --- Location normalization ---
    let normalizedLocation = working;
    const isZip = /^\d{5}$/.test(working);
    const hasState = /,\s*[A-Za-z]{2}$/i.test(working);

    if (!isZip) {
      normalizedLocation = toTitleCase(normalizedLocation);
    }

    if (!isZip && !hasState) {
      normalizedLocation = `${normalizedLocation}, FL`;
    }

    // --- Price parsing ---
    let minPrice = '';
    let maxPrice = '';

    const normalizePrice = (val) => {
      const raw = val.toLowerCase().replace(/[$,]/g, '');
      if (raw.includes('m')) return Math.round(parseFloat(raw) * 1000000);
      if (raw.includes('k')) return Math.round(parseFloat(raw) * 1000);
      return parseInt(raw, 10);
    };

    const priceRangeMatch = location.match(/(\$?\d[\d,.]*[kKmM]?)\s*(?:-|to)\s*(\$?\d[\d,.]*[kKmM]?)/i);
    const underMatch = location.match(/under\s*\$?(\d[\d,.]*[kKmM]?)/i);
    const overMatch = location.match(/over\s*\$?(\d[\d,.]*[kKmM]?)/i);

    if (priceRangeMatch) {
      minPrice = normalizePrice(priceRangeMatch[1]);
      maxPrice = normalizePrice(priceRangeMatch[2]);
    } else if (underMatch) {
      maxPrice = normalizePrice(underMatch[1]);
    } else if (overMatch) {
      minPrice = normalizePrice(overMatch[1]);
    }

    const resolvedLocation = findKnownLocation(normalizedLocation.toLowerCase()) || await resolveWithMapbox(normalizedLocation) || {
      location_search_field: normalizedLocation,
      ss_description: normalizedLocation,
      sort_by: '1'
    };

    // --- Build URL ---
    const baseUrl = "https://space-coast.homes/search/";

    let params = `#ls_conversion=acres&status=active&sold_days=180&location_search_field=${encode(resolvedLocation.location_search_field)}&drive_time=09%3A00&drive_duration=15&drive_avoid_ferry=1&drive_departure=1&ss_locale=en-US&ss_description=${encode(resolvedLocation.ss_description)}&ss_email_freq=40&ss_send_zero_result=1&pgsize=20&startidx=0&sort_by=${encode(resolvedLocation.sort_by || '1')}&company_uuid=4228033&agent_uuid=364e222e-0ca9-400c-a1d1-12724bc51a54&commute=0&buffer_miles=0&ptype=1%2C2%2C9%2C8&searchType=criteria&pstatus=1%2C2%2C11&omit_hidden=true&currency=USD`;

    if (resolvedLocation.center_lat) params += `&center_lat=${encode(resolvedLocation.center_lat)}`;
    if (resolvedLocation.center_lon) params += `&center_lon=${encode(resolvedLocation.center_lon)}`;
    if (resolvedLocation.bounds_north) params += `&bounds_north=${encode(resolvedLocation.bounds_north)}`;
    if (resolvedLocation.bounds_east) params += `&bounds_east=${encode(resolvedLocation.bounds_east)}`;
    if (resolvedLocation.bounds_south) params += `&bounds_south=${encode(resolvedLocation.bounds_south)}`;
    if (resolvedLocation.bounds_west) params += `&bounds_west=${encode(resolvedLocation.bounds_west)}`;
    if (resolvedLocation.center_lat_pan) params += `&center_lat_pan=${encode(resolvedLocation.center_lat_pan)}`;
    if (resolvedLocation.center_lon_pan) params += `&center_lon_pan=${encode(resolvedLocation.center_lon_pan)}`;
    if (resolvedLocation.user_lat) params += `&user_lat=${encode(resolvedLocation.user_lat)}`;
    if (resolvedLocation.user_lon) params += `&user_lon=${encode(resolvedLocation.user_lon)}`;
    if (resolvedLocation.geotype) params += `&geotype=${encode(resolvedLocation.geotype)}`;
    if (resolvedLocation.geospatial) params += `&geospatial=${encode(resolvedLocation.geospatial)}`;
    if (resolvedLocation.zoom) params += `&zoom=${encode(resolvedLocation.zoom)}`;

    if (minPrice) params += `&pricemin=${minPrice}&pricemin_formatted=${encode(Number(minPrice).toLocaleString())}`;
    if (maxPrice) params += `&pricemax=${maxPrice}&pricemax_formatted=${encode(Number(maxPrice).toLocaleString())}`;
    if (beds) params += `&bed_min=${beds}`;

    window.location.href = baseUrl + params;
  });
</script>