---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/LeadForm.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('open-houses', ({ data }) => data.published !== false);

  return entries.map((entry) => ({
    params: { slug: entry.data.slug ?? entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, date, location, summary, heroImage } = entry.data;
---

<BaseLayout
  title={`${title} | Blue Gecko`}
  description={summary}
>
  <main>
    <section class="hero section">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Open House • Early Access</p>
          <h1>{title}</h1>
          <p class="lead">
            Tour this home, compare it against the real competition, and use it as a smarter
            starting point for what else is worth seeing in the same range.
          </p>
          <div class="event-meta">
            <p><strong>When:</strong> {date}</p>
            <p><strong>Where:</strong> {location}</p>
            <p><strong>Why RSVP:</strong> Get the full details, similar homes, and a faster path if this one is close but not quite right.</p>
          </div>
        </div>

        <div class="hero-media">
          <img src={heroImage || '/assets/team.jpg'} alt={title} />
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container intro-grid">
        <div class="card">
          <h2>Get the details</h2>
          <p>
            RSVP to get the full open house details, similar homes in the same lane, and a
            clearer sense of whether this one is actually worth your time in person. If it is
            close but not quite right, we’ll help you find the better fit faster.
          </p>

          <LeadForm
            buttonText="Get Full Details + Similar Homes"
            slug={entry.id}
            source="Open House"
            formType="open-house"
            redirectTo="/thank-you"
            messageLabel="What are you looking for?"
            showName={true}
            showEmail={true}
            showPhone={true}
            showMessage={true}
            requireName={true}
            requireEmail={false}
            requirePhone={false}
            requireAnyContact={true}
          />
        </div>

        <div class="card">
          <h2>Or start with Stella</h2>
          <p>
            Stella is the site concierge. If you want help deciding whether this open house is
            worth the stop, she can help you compare the basics, narrow the field, and point you
            toward other homes that make sense if this one misses the mark.
          </p>
          <p>
            Think of this as the guided route: tour on your own if you want, or start with Stella
            if you’d rather skip the wandering and focus on the homes most likely to fit.
          </p>
          <ul class="feature-list">
            <li>Quick guidance before you drive across town</li>
            <li>Better-fit homes if this one is not the one</li>
            <li>A clearer next step instead of more random tabs</li>
          </ul>
          <div style="margin-top: 1rem;">
            <button data-stella-trigger="open" class="button button-secondary">Start with Stella</button>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-muted">
      <div class="container">
        <div class="card prose-card">
          <h2>What to know before you go</h2>
          <Content />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>