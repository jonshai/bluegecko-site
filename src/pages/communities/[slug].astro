---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allCommunities = await getCollection('communities');
  return allCommunities.map(c => ({
    params: { slug: c.id },
    props: { community: c },
  }));
}

const { community } = Astro.props;
const { Content } = await render(community);
---

<BaseLayout
  title={`${community.data.name} | Communities | Blue Gecko`}
  description={community.data.tagline}
>
  <main>
    <section class="section hero-section">
      <div class="container">
        <nav class="breadcrumb">
          <a href="/communities">← All Communities</a>
        </nav>

        <div class="hero-card">
          {community.data.hero
            ? <img src={community.data.hero} alt={community.data.name} class="hero-img" />
            : <div class="hero-placeholder" />
          }
          <div class="hero-meta">
            <h1>{community.data.name}</h1>
            <p class="hero-caption">{community.data.tagline}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container content-wrap">
        <div class="prose">
          <Content />
        </div>

        <div class="cta-grid">
          <a href="/search" class="cta-card cta-search">
            <span class="cta-icon">🔍</span>
            <div>
              <strong>Search Listings</strong>
              <p>Browse active homes in {community.data.name} and surrounding areas.</p>
            </div>
          </a>
          <button data-stella-trigger="open" class="cta-card cta-stella">
            <span class="cta-icon">💬</span>
            <div>
              <strong>Ask Stella</strong>
              <p>Get quick answers about schools, commutes, pricing, and what it's actually like to live here.</p>
            </div>
          </button>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ── Hero card ── */
  .hero-section {
    padding-bottom: 0;
  }

  .breadcrumb {
    font-size: 0.88rem;
    margin-bottom: 1.5rem;
  }

  .breadcrumb a {
    color: var(--brand, #1f5c4d);
    font-weight: 600;
  }

  .hero-card {
    display: flex;
    border-radius: var(--radius, 18px);
    overflow: hidden;
    background: var(--surface, #fff);
    border: 1px solid var(--line, #d7d1c5);
    box-shadow: var(--shadow, 0 10px 30px rgba(0, 0, 0, 0.08));
  }

  .hero-img,
  .hero-placeholder {
    width: 55%;
    flex-shrink: 0;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  .hero-placeholder {
    background: var(--brand, #1f5c4d);
  }

  .hero-meta {
    flex: 1;
    padding: 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    justify-content: center;
  }

  .hero-meta h1 {
    font-size: 1.5rem;
    line-height: 1.3;
    margin: 0;
  }

  .hero-caption {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-soft);
  }

  /* ── Content ── */
  .content-wrap {
    max-width: 780px;
    padding-top: 2.5rem;
  }

  .prose {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text);
    margin-bottom: 2.5rem;
  }

  .prose p {
    margin-bottom: 1.25rem;
  }

  .prose h2 {
    font-size: 1.35rem;
    margin: 2rem 0 0.75rem;
  }

  .cta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    padding-top: 2rem;
    border-top: 1px solid #e8e6e0;
  }

  .cta-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.5rem;
    border-radius: var(--radius, 18px);
    border: 2px solid #e8e6e0;
    text-decoration: none;
    color: var(--text);
    background: white;
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
    text-align: left;
    transition: border-color 0.15s;
  }

  .cta-card:hover {
    border-color: var(--brand, #1f5c4d);
  }

  .cta-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .cta-card strong {
    display: block;
    font-size: 1rem;
    margin-bottom: 0.3rem;
  }

  .cta-card p {
    font-size: 0.9rem;
    color: var(--text-soft);
    margin: 0;
    line-height: 1.5;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .hero-card {
      flex-direction: column;
    }

    .hero-img,
    .hero-placeholder {
      width: 100%;
      aspect-ratio: 4 / 3;
    }

    .hero-meta h1 {
      font-size: 1.25rem;
    }
  }

  @media (max-width: 600px) {
    .cta-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
