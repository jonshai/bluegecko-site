---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Blue Gecko Homes',
  description = 'Blue Gecko Real Estate',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <div class="cb-strip">
      <div class="container cb-inner">
        <img src="/cb-logo-white.png" alt="Coldwell Banker Realty" class="cb-logo" />
      </div>
    </div>
    <header class="site-header">
      <div class="container header-inner">
        <div class="header-left">
          <a class="brand" href="/">
            <img src="/bg_logo_stroke.png" alt="Blue Gecko Homes" class="brand-logo" />
          </a>
          <nav class="nav" aria-label="Primary">
            <a href="/buy">Buy</a>
            <a href="/list-my-house">Sell</a>
            <a href="/open-house">Open Houses</a>
            <a href="/contact">Contact</a>
          </nav>
        </div>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="container footer-main">
        <p class="agent-line"><strong>Blue Gecko</strong> · Coldwell Banker Realty</p>
        <p class="agent-line">William & Jennifer Whipple · FL Lic. #3535381 / #3535380</p>
        <p class="agent-line">Palm Bay · Melbourne · Sebastian · Space Coast, FL</p>
        <p class="agent-line">321.341.6650</p>
      </div>

      <div class="legal-bar">
        <div class="container legal-inner">
          <div class="legal-left">
            <span class="team-brand">© {new Date().getFullYear()} Blue Gecko, a Coldwell Banker Realty Team</span>

            <div class="legal-links">
              <a href="/privacy" class="privacy-link">PRIVACY POLICY &amp; TERMS</a>
            </div>

            <p class="plain-disclaimer">
              We're real people, not a big corporation — William and Lucky, licensed agents in Florida
              who actually live here. When you reach out, you're talking to us (sometimes assisted by
              our AI, Stella, who is very helpful and always introduces herself). We don't sell your
              info, we don't do spam, and we'll never pressure you. Promise.
            </p>

            <p class="cb-disclaimer">
              © Coldwell Banker Real Estate LLC. All Rights Reserved. Coldwell Banker and the Coldwell Banker logo are trademarks of Coldwell Banker Real Estate LLC.
              The Coldwell Banker® System is comprised of company owned offices which are owned by a subsidiary of Anywhere Advisors LLC and franchised offices which are independently owned and operated.
              The Coldwell Banker System fully supports the principles of the Fair Housing Act and the Equal Opportunity Act.
            </p>

            <p class="mls-disclaimer">
              All information is deemed reliable but not guaranteed and should be independently verified.
              Listing information is provided by the Space Coast MLS and is subject to change.
            </p>
          </div>

          <div class="legal-right">
            <img src="/eho-white.png" alt="Equal Housing Opportunity" class="eho-logo" />
          </div>
        </div>
      </div>
    </footer>

  </body>
</html>

<style>
  .cb-strip {
    background: #0c2a4a;
    color: white;
    position: sticky;
    top: 0;
    z-index: 30;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .cb-inner {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    min-height: 48px;
    padding: 0.25rem 0;
  }

  .cb-logo {
    height: 27px;
    width: auto;
    opacity: 0.96;
    display: block;
  }

  .site-header {
    position: sticky;
    top: 48px;
    z-index: 35;
    background: rgba(247, 246, 242, 0.94);
    backdrop-filter: blur(8px);
    overflow: visible;
  }

  .header-inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: 0;
    padding: 0 0 0.2rem;
  }

  .header-left {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    min-width: 0;
    position: relative;
  }

  .brand {
    display: flex;
    align-items: center;
    flex: 0 0 auto;
    position: relative;
    z-index: 40;
  }

  .brand-logo {
    display: block;
    height: 144px;
    width: auto;
    margin-top: -72px;
    position: relative;
    z-index: 40;
  }

  .nav {
    display: flex;
    gap: 1.1rem;
    flex-wrap: wrap;
    align-items: center;
    margin-top: 0.9rem;
  }

  .nav a {
    color: var(--text-soft);
    font-weight: 600;
    white-space: nowrap;
  }

  .nav a:hover {
    color: var(--text);
  }

  .cta {
    background: var(--accent, #1f5c4d);
    color: white;
    padding: 0.65rem 1rem;
    border-radius: 999px;
    font-weight: 700;
    white-space: nowrap;
    flex: 0 0 auto;
  }

  .cta:hover {
    opacity: 0.9;
    color: white;
  }

  .site-footer {
    margin-top: 3rem;
    background: #f5f5f5;
    color: #333;
    font-size: 14px;
    line-height: 1.6;
  }

  .footer-main {
    padding: 1.25rem 0 1rem;
  }

  .agent-line {
    margin: 0.15rem 0;
  }

  .team-brand {
    margin-top: 0.75rem;
    font-weight: 600;
  }

  .footer-links {
    margin-top: 1rem;
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  .footer-links a {
    color: #0c2a4a;
    text-decoration: none;
    border-bottom: none;
  }

  .footer-links a:hover {
    text-decoration: underline;
  }

  .cb-disclaimer,
  .mls-disclaimer {
    margin-top: 1rem;
    font-size: 12px;
    color: #666;
  }

  .legal-bar {
    background: #0c2a4a;
    color: white;
    padding: 1.5rem 0;
  }

  .legal-inner {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
  }

  .legal-left {
    max-width: 900px;
  }

  .legal-links {
    margin-top: 0.75rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .privacy-link {
    color: white;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.04em;
    border-bottom: none !important;
  }

  .privacy-link:hover {
    text-decoration: underline;
  }

  .plain-disclaimer {
    margin-top: 0.75rem;
    font-size: 12px;
    opacity: 0.82;
    max-width: 680px;
    line-height: 1.6;
  }

  .legal-right {
    display: flex;
    align-items: flex-start;
  }

  .eho-logo {
    height: 26px;
    width: auto;
    display: inline-block;
  }

  /* ── Mobile header: keep logo + nav in the same row ───────────────────────
     On desktop the logo (144px, margin-top: -72px) overhangs the CB strip.
     On mobile we shrink the logo and reduce the overhang, but the flex-direction
     stays row so logo is always left / nav always right — no layout shift.      */

  @media (max-width: 900px) {
    .brand-logo {
      height: 88px;
      margin-top: -42px;
    }

    .nav {
      gap: 0.8rem;
      margin-top: 0.7rem;
    }
  }

  @media (max-width: 600px) {
    .brand-logo {
      height: 108px;
      margin-top: -52px;
    }

    .nav {
      gap: 0.6rem;
      margin-top: 0.55rem;
    }

    .nav a {
      font-size: 0.9rem;
    }
  }

  @media (max-width: 390px) {
    .brand-logo {
      height: 60px;
      margin-top: -28px;
    }

    .nav {
      gap: 0.5rem;
      margin-top: 0.45rem;
    }

    .nav a {
      font-size: 0.85rem;
    }
  }
</style>